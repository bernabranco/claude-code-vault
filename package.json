{
  "name": "claude-code-vault",
  "version": "0.1.2",
  "description": "Local-first markdown knowledge vault for Claude Code — semantic search, graph-aware context, and MCP integration",
  "main": "index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bernabranco/claude-code-vault.git"
  },
  "homepage": "https://github.com/bernabranco/claude-code-vault#readme",
  "bugs": {
    "url": "https://github.com/bernabranco/claude-code-vault/issues"
  },
  "files": [
    "index.js",
    "lib/"
  ],
  "scripts": {
    "dev": "concurrently \"node --watch lib/server.js\" \"cd web && npm run dev\"",
    "build": "cd web && npm run build",
    "start": "node lib/server.js",
    "mcp": "node lib/mcp.js",
    "setup": "npm install && cd web && npm install",
    "cli": "node index.js",
    "vault:index": "node index.js index",
    "vault:search": "node index.js search",
    "vault:export": "node index.js export",
    "vault:list": "node index.js list"
  },
  "bin": {
    "claude-code-vault": "index.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^3.6.0",
    "commander": "11.1.0",
    "express": "^4.18.0",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "model-context-protocol",
    "knowledge-management",
    "knowledge-base",
    "knowledge-graph",
    "markdown",
    "vault",
    "rag",
    "embeddings",
    "semantic-search",
    "local-first",
    "sqlite"
  ],
  "author": "bernabranco",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
